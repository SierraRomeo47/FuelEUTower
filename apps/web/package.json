{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node ./scripts/clear-dev-session.mjs --no-kill && next dev",
    "dev:fresh": "node ./scripts/clear-dev-session.mjs && next dev",
    "build": "next build",
    "verify:css": "node ./scripts/verify-next-css.mjs",
    "smoke:styles": "node ./scripts/smoke-next-styles.mjs",
    "smoke:routes": "node ./scripts/smoke-routes.mjs",
    "test:styles": "npm run build && npm run verify:css && npm run smoke:styles",
    "test:app": "npm run build && npm run verify:css && npm run smoke:styles && npm run smoke:routes",
    "start": "next start",
    "lint": "next lint",
    "ci": "npm run lint && npm run build && npm run verify:css && npm run smoke:styles && npm run smoke:routes",
    "start:clean": "node ./scripts/clear-dev-session.mjs && npm run build && npm run start"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.378.0",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "kill-port": "^2.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
